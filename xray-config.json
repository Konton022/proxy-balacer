{
  "log": {
    "loglevel": "info",
    "access": "/var/log/xray/access.log",
    "error": "/var/log/xray/error.log"
  },
  "api": {
    "tag": "api",
    "services": ["StatsService"]
  },
  "stats": {},
  "policy": {
    "levels": {
      "0": {
        "statsUserUplink": true,
        "statsUserDownlink": true
      }
    },
    "system": {
      "statsInboundUplink": true,
      "statsInboundDownlink": true,
      "statsOutboundUplink": true,
      "statsOutboundDownlink": true
    }
  },
  "inbounds": [
    {
      "tag": "vless-in",
      "listen": "0.0.0.0",
      "port": 8443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "b5e3a7c1-8f2d-4e6a-9b0c-1d3e5f7a9b2c",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "certificates": [
            {
              "certificateFile": "/etc/letsencrypt/live/proxy-balancer.duckdns.org/fullchain.pem",
              "keyFile": "/etc/letsencrypt/live/proxy-balancer.duckdns.org/privkey.pem"
            }
          ],
          "minVersion": "1.2",
          "alpn": ["h2", "http/1.1"]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": ["http", "tls", "quic"]
      }
    },
    {
      "tag": "api-in",
      "listen": "127.0.0.1",
      "port": 8081,
      "protocol": "dokodemo-door",
      "settings": {
        "address": "127.0.0.1"
      }
    }
  ],
  "outbounds": [
    {
      "tag": "proxy-de",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "remote-node-access.duckdns.org",
            "port": 29327,
            "users": [
              {
                "id": "fc3f9ef0-7b2e-43bc-a1b1-cd645fb8af32",
                "encryption": "none",
                "flow": "xtls-rprx-vision"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "serverName": "www.apple.com",
          "fingerprint": "edge",
          "publicKey": "Uxcj7x6WNnL8_xDxGNk1U3BX0Vis5WqXm_xg_pjvYTA",
          "shortId": "cd92e3",
          "spiderX": "/OjljTkpiEEwNhZF"
        }
      }
    },
    {
      "tag": "proxy-us",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "23.172.217.167",
            "port": 53130,
            "users": [
              {
                "id": "094f218f-a179-44a7-af06-81465875c5df",
                "encryption": "none",
                "flow": "xtls-rprx-vision"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "serverName": "download.amd.com",
          "fingerprint": "edge",
          "publicKey": "fO91aDQmLlcZktTcgxeU4orXDdkXgdA6VsUF3csmJ10",
          "shortId": "9a9d",
          "spiderX": "/rHzn4OwHY8beC7p"
        }
      }
    },
    {
      "tag": "proxy-gr",
      "protocol": "vless",
      "settings": {
        "vnext": [
          {
            "address": "proxygrifon.duckdns.org",
            "port": 443,
            "users": [
              {
                "id": "41fa83e8-9096-4ba0-b339-f718324ae012",
                "encryption": "none",
                "flow": "xtls-rprx-vision"
              }
            ]
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "serverName": "cuidateplus.com",
          "fingerprint": "random",
          "publicKey": "88-7-L23OZyz36FwaiY6XcFedFdJ48af0h3lmNcC7BE",
          "shortId": "f6",
          "spiderX": "/JDXmqKzbsXwX2xY"
        }
      }
    },
    {
      "tag": "direct",
      "protocol": "freedom"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "inboundTag": ["api-in"],
        "outboundTag": "api"
      },
      {
        "inboundTag": ["vless-in"],
        "balancerTag": "balancer"
      }
    ],
    "balancers": [
      {
        "tag": "balancer",
        "selector": ["proxy-"],
        "strategy": {
          "type": "leastPing"
        },
        "fallbackTag": "proxy-us"
      }
    ]
  },
  "observatory": {
    "subjectSelector": ["proxy-"],
    "probeUrl": "https://www.google.com/generate_204",
    "probeInterval": "30s",
    "enableConcurrency": true
  }
}
